---
import Layout from "../layouts/Layout.astro";
import ArtworkCard from "../components/ArtworkCard.astro";
import { highlights } from "../data/highlights";
import HeroConsole from "../components/HeroConsole.astro";
---

<Layout title="FAMSF Collection: console hero">
  <HeroConsole />

  <!-- A slice of the page below, so the hero reads in context -->
  <main class="mx-auto max-w-[1360px] px-6 py-16 md:px-10">
    <h2 class="mb-2 font-grotesk text-3xl font-medium tracking-[-0.01em] md:text-4xl">
      Collection highlights
    </h2>
    <p class="mb-8 max-w-[60ch] text-neutral-500">
      Curator-led entry points that cut across collection areas and centuries.
    </p>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {highlights.map((h) => <ArtworkCard {...h} />)}
    </div>
  </main>
</Layout>
