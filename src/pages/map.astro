---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="FAMSF Collection: place of creation map">
  <main class="min-h-screen bg-map-page text-ink">
    <div class="mx-auto max-w-[1360px] px-6 py-16 md:px-10 md:py-24">
      <p class="mb-6 font-mono text-xs uppercase tracking-[0.28em] text-ink/60">
        Fine Arts Museums of San Francisco
      </p>
      <h1
        class="mb-3 font-grotesk text-[clamp(2rem,4.5vw,3.5rem)] font-medium leading-[1.05] tracking-[-0.015em] text-balance"
      >
        Every place of creation, at once.
      </h1>
      <p class="mb-10 max-w-[65ch] text-ink/70">
        Every place of creation in the collection, no pre-filtering. Switch
        between <strong class="font-medium text-ink">Points</strong> (one dot
        per place, sized by works) and
        <strong class="font-medium text-ink">Density</strong> (works pooled
        into hexagons on a log colour scale).
      </p>

      <!-- View mode: individual points vs binned density -->
      <div class="mb-4 inline-flex rounded-full border border-ink/15 p-1 font-mono text-xs">
        <button
          type="button"
          id="mode-points"
          aria-pressed="true"
          class="rounded-full px-4 py-1.5 text-ink/60 transition-colors aria-pressed:bg-ink aria-pressed:text-white"
          >Points</button
        >
        <button
          type="button"
          id="mode-density"
          aria-pressed="false"
          class="rounded-full px-4 py-1.5 text-ink/60 transition-colors aria-pressed:bg-ink aria-pressed:text-white"
          >Density</button
        >
      </div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_320px]">
        <!-- Map panel -->
        <div class="relative">
          <div
            id="map-panel"
            class="relative w-full overflow-hidden rounded-xl border border-ink/10 bg-map-surface"
            style="aspect-ratio: 2 / 1;"
          >
            <svg
              id="map-svg"
              viewBox="0 0 1000 500"
              class="absolute inset-0 h-full w-full cursor-grab touch-pan-y"
              role="img"
              aria-label="World map with a dot for every place of creation in the collection, sized by number of works. Scroll to zoom, drag to pan."
            >
              <!-- graticule + dots injected at runtime -->
            </svg>

            <!-- Tooltip, positioned absolutely over the panel -->
            <div
              id="tooltip"
              role="status"
              class="pointer-events-none absolute z-10 hidden -translate-x-1/2 -translate-y-full whitespace-nowrap rounded-md bg-ink px-2.5 py-1.5 font-mono text-xs text-white shadow-lg"
            >
            </div>

            <!-- Zoom controls -->
            <div class="absolute bottom-3 right-3 z-10 flex flex-col gap-1.5">
              <button
                type="button"
                id="zoom-in"
                aria-label="Zoom in"
                class="flex h-8 w-8 items-center justify-center rounded-md border border-ink/15 bg-white/80 font-mono text-base leading-none text-ink/80 backdrop-blur transition-colors hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-deyoung"
                >+</button
              >
              <button
                type="button"
                id="zoom-out"
                aria-label="Zoom out"
                class="flex h-8 w-8 items-center justify-center rounded-md border border-ink/15 bg-white/80 font-mono text-base leading-none text-ink/80 backdrop-blur transition-colors hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-deyoung"
                >&minus;</button
              >
              <button
                type="button"
                id="zoom-reset"
                aria-label="Reset view"
                class="flex h-8 w-8 items-center justify-center rounded-md border border-ink/15 bg-white/80 font-mono text-[10px] uppercase leading-none tracking-wide text-ink/80 backdrop-blur transition-colors hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-deyoung"
                >Reset</button
              >
            </div>
          </div>

          <p id="caption" class="mt-4 max-w-[70ch] text-sm leading-relaxed text-ink/70" aria-live="polite">
            Loading…
          </p>
        </div>

        <!-- Legend / top places list -->
        <aside>
          <div id="points-legend">
            <h2 class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-ink/60">
              Top 15 places
            </h2>
            <ol id="legend-list" class="m-0 flex list-none flex-col gap-1 p-0">
              <!-- rows injected at runtime -->
            </ol>
          </div>

          <!-- Density-mode legend: log colour scale (populated at runtime) -->
          <div id="density-legend" hidden>
            <h2 class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-ink/60">
              Objects per hexagon
            </h2>
            <div id="density-scale" class="h-3 w-full rounded-full"></div>
            <div class="mt-1.5 flex justify-between font-mono text-[11px] text-ink/50">
              <span>1</span>
              <span id="density-max">-</span>
            </div>
            <!-- Clicked-hexagon breakdown (sits directly under the scale so it's
                 visible without scrolling once a cell is chosen) -->
            <div id="hex-breakdown" class="mt-5" hidden>
              <h3 id="hex-breakdown-head" class="mb-2 font-mono text-xs uppercase tracking-[0.2em] text-ink/60"></h3>
              <ol
                id="hex-breakdown-list"
                class="m-0 flex max-h-[420px] list-none flex-col gap-0.5 overflow-y-auto p-0 pr-1"
              ></ol>
            </div>

            <p class="mt-5 max-w-[40ch] text-[13px] leading-relaxed text-ink/60">
              Each hexagon pools the works from every place that falls inside it,
              coloured on a log scale so sparse regions stay visible next to
              Europe and the US. Hover for the count; click a cell for the
              breakdown.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <script define:vars={{ base }}>
    /**
     * World map of every place of creation. Equirectangular projection,
     * hand-drawn graticule (no tile server / external map lib, GH Pages
     * static-only constraint), dot radius ~ sqrt(n), colour blends toward
     * yellow as n grows. Legend rows and dots share hover/focus highlight.
     */
    const svg = document.getElementById("map-svg");
    const tooltip = document.getElementById("tooltip");
    const panel = document.getElementById("map-panel");
    const legendList = document.getElementById("legend-list");
    const captionEl = document.getElementById("caption");

    const SVG_NS = "http://www.w3.org/2000/svg";
    const WIDTH = 1000;
    const HEIGHT = 500;
    const MIN_R = 2;
    const MAX_R = 40;

    // Design tokens (from global.css), no colour literals in this script.
    const rootStyle = getComputedStyle(document.documentElement);
    const token = (name) => rootStyle.getPropertyValue(name).trim();
    const MAP = {
      surface: token("--color-map-surface"),
      landFill: token("--map-land-fill"),
      landStroke: token("--map-land-stroke"),
      graticule: token("--map-graticule"),
      graticuleAxis: token("--map-graticule-axis"),
      markerStroke: token("--map-marker-stroke"),
      hexStroke: token("--map-hex-stroke"),
      hexFillOpacity: token("--map-hex-fill-opacity"),
    };

    // --- Zoom / pan state ---------------------------------------------
    // viewBox is [x, y, w, h] in world units (0..1000 / 0..500).
    // w shrinks as we zoom in; min w = full extent, max zoom ~20x -> w ~= 50.
    const FULL_VB = { x: 0, y: 0, w: WIDTH, h: HEIGHT };
    const MIN_VB_W = WIDTH / 20; // ~50, max zoom
    const MAX_VB_W = WIDTH; // full extent, min zoom
    let vb = { ...FULL_VB };
    let baseDotsGroup = null; // populated once dots are drawn, for rescaling

    function applyViewBox() {
      svg.setAttribute("viewBox", `${vb.x} ${vb.y} ${vb.w} ${vb.h}`);
      rescaleDots();
    }

    function clampViewBox(next) {
      let { x, y, w, h } = next;
      w = Math.min(MAX_VB_W, Math.max(MIN_VB_W, w));
      h = (w * HEIGHT) / WIDTH;
      x = Math.min(WIDTH - w, Math.max(0, x));
      y = Math.min(HEIGHT - h, Math.max(0, y));
      return { x, y, w, h };
    }

    // Convert a pointer's client coords to world (viewBox) coords.
    function clientToWorld(clientX, clientY) {
      const rect = svg.getBoundingClientRect();
      const px = (clientX - rect.left) / rect.width;
      const py = (clientY - rect.top) / rect.height;
      return { x: vb.x + px * vb.w, y: vb.y + py * vb.h };
    }

    function zoomAt(clientX, clientY, factor) {
      const before = clientToWorld(clientX, clientY);
      const newW = vb.w * factor;
      const clampedW = Math.min(MAX_VB_W, Math.max(MIN_VB_W, newW));
      const scale = clampedW / vb.w;
      // Keep the world point under the cursor stationary.
      const newX = before.x - (before.x - vb.x) * scale;
      const newY = before.y - (before.y - vb.y) * scale;
      vb = clampViewBox({ x: newX, y: newY, w: clampedW, h: (clampedW * HEIGHT) / WIDTH });
      applyViewBox();
    }

    function zoomAtCenter(factor) {
      const rect = svg.getBoundingClientRect();
      zoomAt(rect.left + rect.width / 2, rect.top + rect.height / 2, factor);
    }

    function resetView() {
      animateViewBox({ ...FULL_VB });
    }

    // Ease the viewBox from its current value to a target (used by legend
    // click-to-zoom + reset). Skipped under reduced motion.
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let animRAF = 0;
    function animateViewBox(target) {
      const to = clampViewBox(target);
      if (prefersReducedMotion) {
        vb = to;
        applyViewBox();
        return;
      }
      cancelAnimationFrame(animRAF);
      const from = { ...vb };
      const t0 = performance.now();
      const DUR = 520;
      const ease = (p) => 1 - Math.pow(1 - p, 3); // easeOutCubic
      function step(now) {
        const p = Math.min(1, (now - t0) / DUR);
        const k = ease(p);
        vb = {
          x: from.x + (to.x - from.x) * k,
          y: from.y + (to.y - from.y) * k,
          w: from.w + (to.w - from.w) * k,
          h: from.h + (to.h - from.h) * k,
        };
        applyViewBox();
        if (p < 1) animRAF = requestAnimationFrame(step);
      }
      animRAF = requestAnimationFrame(step);
    }

    // Zoom the map to centre on a world point (e.g. a legend place's dot).
    function zoomToWorld(wx, wy, targetW = WIDTH / 8) {
      const w = Math.min(MAX_VB_W, Math.max(MIN_VB_W, targetW));
      const h = (w * HEIGHT) / WIDTH;
      animateViewBox({ x: wx - w / 2, y: wy - h / 2, w, h });
    }

    function panBy(dxClient, dyClient) {
      const rect = svg.getBoundingClientRect();
      const dxWorld = (dxClient / rect.width) * vb.w;
      const dyWorld = (dyClient / rect.height) * vb.h;
      vb = clampViewBox({ x: vb.x - dxWorld, y: vb.y - dyWorld, w: vb.w, h: vb.h });
      applyViewBox();
    }

    // Partially counter-scale markers: fully constant screen size (÷zoom) makes
    // them tiny when zoomed in, so let them grow with zoom^0.45, bigger as you
    // zoom in, but not so much they balloon back to overlapping blobs.
    function rescaleDots() {
      if (!baseDotsGroup) return;
      const zoomFactor = WIDTH / vb.w; // 1 at full extent, up to 20 at max zoom
      const shrink = Math.pow(zoomFactor, 0.55); // < zoomFactor, so dots grow with zoom
      for (const circle of baseDotsGroup.children) {
        const baseR = Number(circle.getAttribute("data-base-r"));
        if (!baseR) continue;
        const isHighlighted = circle.getAttribute("data-highlighted") === "1";
        const boost = Number(circle.getAttribute("data-highlight-boost")) || 1;
        const effectiveR = (baseR / shrink) * boost;
        circle.setAttribute("r", String(effectiveR));
        if (isHighlighted) {
          circle.setAttribute("stroke", MAP.markerStroke);
          circle.setAttribute("stroke-width", String(2 / shrink));
        }
      }
    }

    function project(lat, lng) {
      const x = ((lng + 180) / 360) * WIDTH;
      const y = ((90 - lat) / 180) * HEIGHT;
      return { x, y };
    }

    function drawGraticule() {
      const g = document.createElementNS(SVG_NS, "g");
      g.setAttribute("stroke", MAP.graticule);
      g.setAttribute("stroke-width", "1");

      // Background panel (light)
      const bg = document.createElementNS(SVG_NS, "rect");
      bg.setAttribute("x", "0");
      bg.setAttribute("y", "0");
      bg.setAttribute("width", String(WIDTH));
      bg.setAttribute("height", String(HEIGHT));
      bg.setAttribute("fill", MAP.surface);
      bg.setAttribute("stroke", "none");
      svg.appendChild(bg);

      // Equator + prime meridian slightly darker
      for (let lng = -180; lng <= 180; lng += 30) {
        const { x } = project(0, lng);
        const line = document.createElementNS(SVG_NS, "line");
        line.setAttribute("x1", String(x));
        line.setAttribute("y1", "0");
        line.setAttribute("x2", String(x));
        line.setAttribute("y2", String(HEIGHT));
        if (lng === 0) line.setAttribute("stroke", MAP.graticuleAxis);
        g.appendChild(line);
      }
      for (let lat = -90; lat <= 90; lat += 30) {
        const { y } = project(lat, 0);
        const line = document.createElementNS(SVG_NS, "line");
        line.setAttribute("x1", "0");
        line.setAttribute("y1", String(y));
        line.setAttribute("x2", String(WIDTH));
        line.setAttribute("y2", String(y));
        if (lat === 0) line.setAttribute("stroke", MAP.graticuleAxis);
        g.appendChild(line);
      }
      svg.appendChild(g);
    }

    // Land outlines (Natural Earth 110m, pre-projected to the 1000×500 space)
    // so the dots read against actual continents, not an empty grid.
    async function drawLand() {
      try {
        const res = await fetch(`${base}/data/land_paths.json`);
        const land = await res.json();
        const path = document.createElementNS(SVG_NS, "path");
        path.setAttribute("d", land.d);
        path.setAttribute("fill", MAP.landFill);
        path.setAttribute("stroke", MAP.landStroke);
        path.setAttribute("stroke-width", "0.6");
        path.setAttribute("vector-effect", "non-scaling-stroke");
        path.setAttribute("pointer-events", "none");
        svg.appendChild(path);
      } catch {
        // If the land file is missing the map still works as dots + grid.
      }
    }

    // Brand hues to interpolate through as n grows: teal -> purple -> yellow
    const STOPS = [
      { n: 0, rgb: [0, 105, 115] }, // deyoung
      { n: 0.5, rgb: [102, 83, 166] }, // amethyst
      { n: 1, rgb: [240, 203, 9] }, // yellow
    ];

    function colorFor(t) {
      // t in [0,1]; pick the surrounding pair of stops and lerp
      let lo = STOPS[0];
      let hi = STOPS[STOPS.length - 1];
      for (let i = 0; i < STOPS.length - 1; i++) {
        if (t >= STOPS[i].n && t <= STOPS[i + 1].n) {
          lo = STOPS[i];
          hi = STOPS[i + 1];
          break;
        }
      }
      const span = hi.n - lo.n || 1;
      const localT = (t - lo.n) / span;
      const rgb = lo.rgb.map((c, i) => Math.round(c + (hi.rgb[i] - c) * localT));
      return `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
    }

    function showTooltip(x, y, text) {
      tooltip.textContent = text;
      tooltip.style.left = `${x}px`;
      tooltip.style.top = `${y - 10}px`;
      tooltip.classList.remove("hidden");
    }
    function hideTooltip() {
      tooltip.classList.add("hidden");
    }

    async function init() {
      const res = await fetch(`${base}/data/places.ndjson`);
      const text = await res.text();
      const lines = text.split("\n").filter((l) => l.trim().length > 0);

      const places = lines.map((l) => JSON.parse(l));
      const mapped = places.filter((p) => p.lat != null && p.lng != null);
      const unmapped = places.length - mapped.length;

      const totalObjects = places.reduce((sum, p) => sum + p.n, 0);
      const mappedObjects = mapped.reduce((sum, p) => sum + p.n, 0);

      // Continent-level read from path[1] (path[0] is always "World")
      const byContinent = new Map();
      for (const p of mapped) {
        const continent = Array.isArray(p.path) && p.path.length > 1 ? p.path[1] : "Unknown";
        byContinent.set(continent, (byContinent.get(continent) || 0) + p.n);
      }
      const topContinents = Array.from(byContinent.entries()).sort((a, b) => b[1] - a[1]);
      const [topName, topN] = topContinents[0];
      const topPct = Math.round((topN / mappedObjects) * 100);
      const [secondName, secondN] = topContinents[1] || ["", 0];
      const secondPct = Math.round((secondN / mappedObjects) * 100);

      drawGraticule();
      await drawLand();

      const maxN = Math.max(...mapped.map((p) => p.n));
      const minN = Math.min(...mapped.map((p) => p.n));
      const sqrtMax = Math.sqrt(maxN);
      const sqrtMin = Math.sqrt(minN);

      function radiusFor(n) {
        const t = (Math.sqrt(n) - sqrtMin) / (sqrtMax - sqrtMin || 1);
        return MIN_R + t * (MAX_R - MIN_R);
      }

      const dotsGroup = document.createElementNS(SVG_NS, "g");
      const circleById = new Map();

      mapped.forEach((p, i) => {
        const { x, y } = project(p.lat, p.lng);
        const r = radiusFor(p.n);
        const t = Math.sqrt(p.n) / sqrtMax;
        const circle = document.createElementNS(SVG_NS, "circle");
        circle.setAttribute("cx", String(x));
        circle.setAttribute("cy", String(y));
        circle.setAttribute("r", String(r));
        circle.setAttribute("data-base-r", String(r));
        circle.setAttribute("fill", colorFor(t));
        circle.setAttribute("fill-opacity", "0.55");
        circle.setAttribute("stroke", "none");
        circle.setAttribute("tabindex", "0");
        circle.setAttribute("role", "button");
        circle.setAttribute("data-id", String(i));
        circle.setAttribute(
          "aria-label",
          `${p.place}: ${p.n.toLocaleString()} object${p.n === 1 ? "" : "s"}`,
        );
        circle.classList.add("map-dot");

        const label = `${p.place}: ${p.n.toLocaleString()} object${p.n === 1 ? "" : "s"}`;

        function onEnter() {
          const panelRect = panel.getBoundingClientRect();
          const svgRect = svg.getBoundingClientRect();
          // Map world coords -> current on-screen position via the live viewBox,
          // then express relative to the panel (tooltip is positioned over panel).
          const px = ((x - vb.x) / vb.w) * svgRect.width + (svgRect.left - panelRect.left);
          const py = ((y - vb.y) / vb.h) * svgRect.height + (svgRect.top - panelRect.top);
          showTooltip(px, py, label);
          const zoomFactor = WIDTH / vb.w;
          circle.setAttribute("stroke", MAP.markerStroke);
          circle.setAttribute("stroke-width", String(1.5 / zoomFactor));
          circle.setAttribute("fill-opacity", "0.9");
          circle.setAttribute("data-highlighted", "1");
        }
        function onLeave() {
          hideTooltip();
          circle.setAttribute("stroke", "none");
          circle.setAttribute("fill-opacity", "0.55");
          circle.removeAttribute("data-highlighted");
        }

        circle.addEventListener("mouseenter", onEnter);
        circle.addEventListener("mouseleave", onLeave);
        circle.addEventListener("focus", onEnter);
        circle.addEventListener("blur", onLeave);

        dotsGroup.appendChild(circle);
        circleById.set(i, circle);
      });
      svg.appendChild(dotsGroup);
      baseDotsGroup = dotsGroup;

      // --- Density (hexbin) layer --------------------------------------------
      // Bin the points into hexagons and colour each by log(total objects) so
      // the 1→2,934 skew doesn't wash everything but France/US to one hue.
      // Hexes live in world (viewBox) units, so they scale with zoom for free.
      const HEX_R = 16; // world units; ~ bin size at full extent
      const hexGroup = document.createElementNS(SVG_NS, "g");
      hexGroup.setAttribute("data-layer", "hex");
      hexGroup.style.display = "none";

      function hexKey(cx, cy) {
        return `${cx.toFixed(1)},${cy.toFixed(1)}`;
      }
      // Pointy-top hex lattice: rows offset by half a column.
      const hexW = Math.sqrt(3) * HEX_R;
      const hexVert = 1.5 * HEX_R;
      const bins = new Map();
      for (const p of mapped) {
        const { x, y } = project(p.lat, p.lng);
        const row = Math.round(y / hexVert);
        const off = (row % 2) * (hexW / 2);
        const col = Math.round((x - off) / hexW);
        const cx = col * hexW + off;
        const cy = row * hexVert;
        const k = hexKey(cx, cy);
        let b = bins.get(k);
        if (!b) {
          b = { cx, cy, n: 0, list: [] };
          bins.set(k, b);
        }
        b.n += p.n;
        b.list.push(p);
      }
      for (const b of bins.values()) b.list.sort((a, z) => z.n - a.n);
      const hexMax = Math.max(...Array.from(bins.values()).map((b) => b.n));
      const logMax = Math.log(hexMax + 1);

      function hexPath(cx, cy, r) {
        let d = "";
        for (let i = 0; i < 6; i++) {
          const a = (Math.PI / 180) * (60 * i - 90); // pointy-top
          const px = cx + r * Math.cos(a);
          const py = cy + r * Math.sin(a);
          d += (i === 0 ? "M" : "L") + px.toFixed(2) + "," + py.toFixed(2);
        }
        return d + "Z";
      }

      // Render a clicked hexagon's full place breakdown into the side panel.
      const breakdownEl = document.getElementById("hex-breakdown");
      const breakdownHead = document.getElementById("hex-breakdown-head");
      const breakdownList = document.getElementById("hex-breakdown-list");
      let selectedHex = null; // the currently-selected <path>, to un-mark it
      function showBreakdown(hexEl, b, header) {
        if (!breakdownEl) return;
        if (selectedHex && selectedHex !== hexEl) {
          selectedHex.removeAttribute("data-selected");
          selectedHex.setAttribute("stroke", MAP.hexStroke);
          selectedHex.setAttribute("stroke-width", "0.5");
        }
        selectedHex = hexEl;
        hexEl.setAttribute("data-selected", "1");
        hexEl.setAttribute("stroke", MAP.markerStroke);
        hexEl.setAttribute("stroke-width", "1.5");
        breakdownHead.textContent = header;
        breakdownList.innerHTML = "";
        // Group places by tier so a country doesn't sit flat next to its own
        // states/cities. Sections render in coarse→fine order.
        const TIERS = [
          ["continent", "Continents & regions"],
          ["country", "Countries"],
          ["region", "States & regions"],
          ["city", "Cities"],
        ];
        for (const [tier, label] of TIERS) {
          const items = b.list.filter((p) => (p.tier || "region") === tier);
          if (!items.length) continue;
          const head = document.createElement("li");
          head.className =
            "mt-2 mb-0.5 px-2 font-mono text-[10px] uppercase tracking-[0.18em] text-ink/45 first:mt-0";
          head.textContent = label;
          breakdownList.appendChild(head);
          for (const p of items) {
            const li = document.createElement("li");
            li.className =
              "flex items-center justify-between gap-3 rounded px-2 py-1 font-mono text-[13px] text-ink/80";
            li.innerHTML = `<span class="truncate">${p.place}</span><span class="shrink-0 tabular-nums text-ink/50">${p.n.toLocaleString()}</span>`;
            breakdownList.appendChild(li);
          }
        }
        breakdownEl.hidden = false;
      }
      // Deselect: hide the breakdown, restore the plain density legend.
      function clearBreakdown() {
        if (selectedHex) {
          selectedHex.removeAttribute("data-selected");
          selectedHex.setAttribute("stroke", MAP.hexStroke);
          selectedHex.setAttribute("stroke-width", "0.5");
          selectedHex = null;
        }
        if (breakdownEl) breakdownEl.hidden = true;
      }
      // Click on empty map (not a hex) clears the selection.
      svg.addEventListener("click", (e) => {
        if (!(e.target instanceof Element) || !e.target.closest('[data-layer="hex"] path')) {
          clearBreakdown();
        }
      });
      // Escape clears it too.
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") clearBreakdown();
      });

      for (const b of bins.values()) {
        const t = Math.log(b.n + 1) / logMax; // log-scaled colour
        const hex = document.createElementNS(SVG_NS, "path");
        hex.setAttribute("d", hexPath(b.cx, b.cy, HEX_R * 0.95));
        hex.setAttribute("fill", colorFor(t));
        hex.setAttribute("fill-opacity", MAP.hexFillOpacity);
        hex.setAttribute("stroke", MAP.hexStroke);
        hex.setAttribute("stroke-width", "0.5");
        hex.setAttribute("vector-effect", "non-scaling-stroke");
        hex.setAttribute("tabindex", "0");
        hex.setAttribute("role", "button");
        const nPlaces = b.list.length;
        const header = `${b.n.toLocaleString()} object${b.n === 1 ? "" : "s"} from ${nPlaces} place${nPlaces === 1 ? "" : "s"}`;
        hex.setAttribute("aria-label", `${header}. Click for breakdown.`);
        function hEnter() {
          const panelRect = panel.getBoundingClientRect();
          const svgRect = svg.getBoundingClientRect();
          const px = ((b.cx - vb.x) / vb.w) * svgRect.width + (svgRect.left - panelRect.left);
          const py = ((b.cy - vb.y) / vb.h) * svgRect.height + (svgRect.top - panelRect.top);
          showTooltip(px, py, header);
          hex.setAttribute("stroke", MAP.markerStroke);
          hex.setAttribute("stroke-width", "1.5");
        }
        function hLeave() {
          hideTooltip();
          if (hex.getAttribute("data-selected") === "1") return; // keep selection outline
          hex.setAttribute("stroke", MAP.hexStroke);
          hex.setAttribute("stroke-width", "0.5");
        }
        hex.addEventListener("mouseenter", hEnter);
        hex.addEventListener("mouseleave", hLeave);
        hex.addEventListener("focus", hEnter);
        hex.addEventListener("blur", hLeave);
        // Click → show the full place breakdown in the side panel.
        hex.addEventListener("click", () => showBreakdown(hex, b, header));
        hexGroup.appendChild(hex);
      }
      svg.appendChild(hexGroup);

      // Density legend: paint the log colour ramp + show the max.
      const scaleEl = document.getElementById("density-scale");
      if (scaleEl) {
        const stops = [];
        for (let i = 0; i <= 6; i++) {
          const t = i / 6;
          stops.push(`${colorFor(t)} ${Math.round(t * 100)}%`);
        }
        scaleEl.style.background = `linear-gradient(90deg, ${stops.join(", ")})`;
      }
      const maxEl = document.getElementById("density-max");
      if (maxEl) maxEl.textContent = hexMax.toLocaleString();

      // Mode toggle: swap the dot layer for the hexbin layer.
      const modePoints = document.getElementById("mode-points");
      const modeDensity = document.getElementById("mode-density");
      const densityLegend = document.getElementById("density-legend");
      const pointsLegend = document.getElementById("points-legend");
      function setMode(mode, updateHash = true) {
        const density = mode === "density";
        dotsGroup.style.display = density ? "none" : "";
        hexGroup.style.display = density ? "" : "none";
        modePoints.setAttribute("aria-pressed", String(!density));
        modeDensity.setAttribute("aria-pressed", String(density));
        if (densityLegend) densityLegend.hidden = !density;
        if (pointsLegend) pointsLegend.hidden = density;
        clearBreakdown(); // drop any hex selection when switching modes
        hideTooltip();
        // Reflect the mode in the URL hash (#points / #density) for deep-linking.
        if (updateHash) {
          const hash = density ? "#density" : "#points";
          if (location.hash !== hash) history.replaceState(null, "", hash);
        }
      }
      modePoints.addEventListener("click", () => setMode("points"));
      modeDensity.addEventListener("click", () => setMode("density"));

      // Restore mode from the URL hash on load, and follow back/forward + edits.
      const modeFromHash = () => (location.hash === "#density" ? "density" : "points");
      setMode(modeFromHash(), false);
      window.addEventListener("hashchange", () => setMode(modeFromHash(), false));

      // Legend: top 15 by n, cross-highlights the matching dot
      const top15 = mapped
        .map((p, i) => ({ ...p, index: i }))
        .sort((a, b) => b.n - a.n)
        .slice(0, 15);

      top15.forEach((p) => {
        const li = document.createElement("li");
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className =
          "flex w-full items-center justify-between gap-3 rounded-md px-2.5 py-1.5 text-left font-mono text-[13px] text-ink/80 transition-colors hover:bg-ink/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-deyoung motion-reduce:transition-none";
        btn.innerHTML = `<span class="truncate">${p.place}</span><span class="shrink-0 tabular-nums text-ink/50">${p.n.toLocaleString()}</span>`;

        const circle = circleById.get(p.index);

        function highlight() {
          if (!circle) return;
          circle.setAttribute("fill-opacity", "1");
          circle.setAttribute("data-highlighted", "1");
          circle.setAttribute("data-highlight-boost", "1.3");
          rescaleDots();
        }
        function unhighlight() {
          if (!circle) return;
          circle.setAttribute("stroke", "none");
          circle.setAttribute("fill-opacity", "0.55");
          circle.removeAttribute("data-highlighted");
          circle.removeAttribute("data-highlight-boost");
          rescaleDots();
        }

        btn.addEventListener("mouseenter", highlight);
        btn.addEventListener("mouseleave", unhighlight);
        btn.addEventListener("focus", highlight);
        btn.addEventListener("blur", unhighlight);

        // Click a place → fly the map to its dot and hold it highlighted.
        btn.setAttribute("aria-label", `Zoom to ${p.place}`);
        btn.addEventListener("click", () => {
          if (!circle) return;
          const wx = Number(circle.getAttribute("cx"));
          const wy = Number(circle.getAttribute("cy"));
          zoomToWorld(wx, wy);
          highlight();
        });

        li.appendChild(btn);
        legendList.appendChild(li);
      });

      const pctPlaces = ((mapped.length / places.length) * 100).toFixed(1);
      const pctObjects = ((mappedObjects / totalObjects) * 100).toFixed(1);

      captionEl.textContent =
        `${mapped.length.toLocaleString()} of ${places.length.toLocaleString()} places mapped ` +
        `(${pctPlaces}% of places, ${pctObjects}% of ${totalObjects.toLocaleString()} objects). ` +
        `${topName} and ${secondName} alone account for ${topPct + secondPct}% of mapped objects` +
        ` (${topName} ${topPct}%, ${secondName} ${secondPct}%). The collection reads as heavily ` +
        `Euro/American, with everywhere else thinner and more scattered. ` +
        `${unmapped.toLocaleString()} place${unmapped === 1 ? "" : "s"} had no resolvable coordinates and are omitted from the map.`;
    }

    // --- Wheel zoom, drag pan, buttons, touch --------------------------
    function setupZoomPan() {
      const ZOOM_STEP = 1.3;

      svg.addEventListener(
        "wheel",
        (e) => {
          e.preventDefault();
          const factor = e.deltaY > 0 ? ZOOM_STEP : 1 / ZOOM_STEP;
          zoomAt(e.clientX, e.clientY, factor);
        },
        { passive: false },
      );

      document.getElementById("zoom-in").addEventListener("click", () => zoomAtCenter(1 / ZOOM_STEP));
      document.getElementById("zoom-out").addEventListener("click", () => zoomAtCenter(ZOOM_STEP));
      document.getElementById("zoom-reset").addEventListener("click", resetView);

      // Pointer-based drag pan (works for mouse + single-finger touch).
      let dragging = false;
      let lastX = 0;
      let lastY = 0;

      // Only start a real pan (and capture the pointer) once the pointer has
      // actually moved past a small threshold. A plain tap therefore never
      // captures, so its click still reaches the hex/dot underneath.
      let pointerDown = false;
      let captured = false;
      let downId = 0;
      const DRAG_THRESHOLD = 4; // px

      svg.addEventListener("pointerdown", (e) => {
        if (e.pointerType === "touch" && e.isPrimary === false) return;
        pointerDown = true;
        dragging = false;
        captured = false;
        downId = e.pointerId;
        lastX = e.clientX;
        lastY = e.clientY;
      });
      svg.addEventListener("pointermove", (e) => {
        if (!pointerDown) return;
        const dx = e.clientX - lastX;
        const dy = e.clientY - lastY;
        if (!dragging && Math.abs(dx) + Math.abs(dy) < DRAG_THRESHOLD) return;
        if (!captured) {
          captured = true;
          dragging = true;
          svg.setPointerCapture(downId);
          svg.classList.remove("cursor-grab");
          svg.classList.add("cursor-grabbing");
        }
        lastX = e.clientX;
        lastY = e.clientY;
        panBy(dx, dy);
      });
      function endDrag(e) {
        pointerDown = false;
        dragging = false;
        svg.classList.remove("cursor-grabbing");
        svg.classList.add("cursor-grab");
        if (captured) {
          try {
            svg.releasePointerCapture(e.pointerId);
          } catch {
            /* no-op: pointer capture may already be released */
          }
          captured = false;
        }
      }
      svg.addEventListener("pointerup", endDrag);
      svg.addEventListener("pointercancel", endDrag);

      // Basic pinch-to-zoom: track two touch points, zoom by distance ratio.
      let pinchStartDist = null;
      let pinchStartVbW = null;
      svg.addEventListener(
        "touchmove",
        (e) => {
          if (e.touches.length !== 2) {
            pinchStartDist = null;
            return;
          }
          e.preventDefault();
          const [t1, t2] = e.touches;
          const dist = Math.hypot(t2.clientX - t1.clientX, t2.clientY - t1.clientY);
          const midX = (t1.clientX + t2.clientX) / 2;
          const midY = (t1.clientY + t2.clientY) / 2;
          if (pinchStartDist == null) {
            pinchStartDist = dist;
            pinchStartVbW = vb.w;
            return;
          }
          const targetW = clampViewBox({ ...vb, w: pinchStartVbW * (pinchStartDist / dist) }).w;
          zoomAt(midX, midY, targetW / vb.w);
        },
        { passive: false },
      );
      svg.addEventListener("touchend", (e) => {
        if (e.touches.length < 2) pinchStartDist = null;
      });
    }

    setupZoomPan();
    init();
  </script>

  <style>
    @media (prefers-reduced-motion: no-preference) {
      .map-dot {
        transition:
          r 0.15s ease-out,
          fill-opacity 0.15s ease-out;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .map-dot {
        transition: none;
      }
    }
  </style>
</Layout>
